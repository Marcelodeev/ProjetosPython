QWidget {
    background-color: #1e1e2f;
    color: white;
}

QLabel {
    color: #f5f5f5;
}

QPushButton {
    border-radius: 12px;
    font-size: 14px;
    font-weight: bold;
    padding: 10px;
}

QPushButton#btc {
    background-color: #2ecc71;
    color: black;
}

QPushButton#btc:hover {
    background-color: #27ae60;
}

QPushButton#usd {
    background-color: #3498db;
    color: white;
}

QPushButton#usd:hover {
    background-color: #2980b9;
}